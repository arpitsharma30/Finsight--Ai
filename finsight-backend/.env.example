# Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file — it's in .gitignore

# -------------------------------------------
# AI Chat (Optional)
# Get a free key at https://console.groq.com
# Without this, chat works in local fallback mode
# -------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# -------------------------------------------
# Database (Optional)
# Only needed for production (AWS RDS PostgreSQL)
# Defaults to local SQLite if not set
# -------------------------------------------
SQLALCHEMY_DATABASE_URL=postgresql://dbuser:password@your-rds-endpoint:5432/postgres

# -------------------------------------------
# JWT Secret Key (Optional)
# Change this to a long random string in production
# -------------------------------------------
SECRET_KEY=change_this_to_a_long_random_secret_key

# -------------------------------------------
# Server Port (Optional - defaults to 8000)
# -------------------------------------------
PORT=8000
